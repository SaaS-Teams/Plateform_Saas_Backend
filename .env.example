# =================================================================
# SaaS Marketing Platform - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# NE JAMAIS committer le fichier .env
# =================================================================

# Base de données PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/saas_db
DB_USERNAME=postgres
DB_PASSWORD=change_me_password

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=change_me_redis_password

# Sécurité JWT
JWT_SECRET=change_me_generate_a_strong_secret_of_at_least_256_bits
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Email (SendGrid)
SENDGRID_API_KEY=change_me_sendgrid_api_key
MAIL_FROM=no-reply@votresaaS.com

# Configuration Application
APP_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=dev
